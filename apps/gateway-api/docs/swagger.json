  ],
  "swagger": "2.0",
  "info": {
    "description": "XSonar Gateway API for accessing Twitter/X data through a unified proxy layer. Supports user profiles, tweets, search, lists, communities, and collector tasks. All endpoints require a valid gateway bearer token in the Authorization header.",
    "title": "XSonar Gateway API",
    "version": "v1"
  },
  "basePath": "/",
  "paths": {
    "/v1/collector/tasks/periodic": {
      "post": {
        "security": [
          {
            "gatewayBearer": []
          }
        ],
        "description": "创建一个周期性执行的采集任务，按指定频率持续采集符合关键词的推文。适用于长期监控特定话题的场景。",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "schemes": [
          "https"
        ],
        "tags": [
          "Gateway API"
        ],
        "summary": "创建周期采集任务",
        "operationId": "createPeriodicCollectorTask",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "task_id",
                "keyword"
              ],
              "properties": {
                "frequency_seconds": {
                  "type": "integer",
                  "example": 3600
                },
                "keyword": {
                  "type": "string",
                  "example": "XSonar"
                },
                "priority": {
                  "type": "integer",
                  "example": 1
                },
                "required_count": {
                  "type": "integer",
                  "example": 1000
                },
                "task_id": {
                  "type": "string",
                  "example": "task_001"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer"
                },
                "data": {},
                "message": {
                  "type": "string"
                },
                "request_id": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1/collector/tasks/range": {
      "post": {
        "security": [
          {
            "gatewayBearer": []
          }
        ],
        "description": "创建一个在指定时间范围内执行一次性的采集任务。适用于回溯历史数据或限时监控场景。",
