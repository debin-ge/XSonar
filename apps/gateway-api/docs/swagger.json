        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "task_id",
                "keyword"
              ],
              "properties": {
                "keyword": {
                  "type": "string",
                  "example": "XSonar"
                },
                "priority": {
                  "type": "integer",
                  "example": 1
                },
                "required_count": {
                  "type": "integer",
                  "example": 500
                },
                "since": {
                  "type": "string",
                  "example": "2024-01-01T00:00:00Z"
                },
                "task_id": {
                  "type": "string",
                  "example": "task_002"
                },
                "until": {
                  "type": "string",
                  "example": "2024-12-31T23:59:59Z"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer"
                },
                "data": {},
                "message": {
                  "type": "string"
                },
                "request_id": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
