# Docker Compose sample env file for local / single-host deployment.
# Precedence:
#   1. Service-specific env, e.g. GATEWAY_API_* / PROVIDER_RPC_*
#   2. Common env, e.g. COMMON_*
#   3. YAML config files mounted into each service
#   4. Built-in defaults inside code / docker-compose
#
# Typical usage:
#   1. Copy this file to .env
#   2. Replace secrets and upstream credentials
#   3. Start with: ENV_FILE=.env docker compose up -d
#
# Notes:
# - Host-facing ports are configured below with HOST_*_PORT.
# - Internal service discovery defaults are generated in docker-compose.yml.
# - Unless you are changing topology, you usually only need to edit secrets,
#   upstream credentials, and possibly host ports.

# Host ports published by docker-compose on the machine running containers.
# These do not change the port listened on inside the container.
HOST_GATEWAY_API_PORT=8080
HOST_CONSOLE_API_PORT=8081
HOST_POSTGRES_PORT=5432
HOST_REDIS_PORT=6379

# PostgreSQL container bootstrap settings.
# These are used by the postgres container itself, and also participate in the
# generated COMMON_POSTGRES_DSN unless you explicitly override that DSN.
POSTGRES_USER=xsonar
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=xsonar
# SSL mode appended to the generated PostgreSQL DSN.
# For local docker-compose, "disable" is usually correct.
POSTGRES_SSLMODE=disable

# Common application settings shared by multiple services.
# COMMON_MODE affects environment-sensitive behavior in some services.
# Expected values are typically "dev", "test", or "pro".
COMMON_MODE=dev
# Timeout units are milliseconds unless otherwise stated.
# This is a shared default request timeout for services that expose Timeout.
COMMON_TIMEOUT=5000
COMMON_SECRET_MASTER_KEY=

# Optional common overrides.
# Uncomment only when you need to override docker-compose defaults.
#
# Internal RPC target list used by services that depend on access-rpc.
# Multiple endpoints can be comma-separated.
# COMMON_ACCESS_RPC_ENDPOINTS=access-rpc:9001
#
# Default gRPC client timeout for access-rpc calls, in milliseconds.
# COMMON_ACCESS_RPC_TIMEOUT=2000
#
# Internal RPC target list used by services that depend on policy-rpc.
# COMMON_POLICY_RPC_ENDPOINTS=policy-rpc:9002
#
# Default gRPC client timeout for policy-rpc calls, in milliseconds.
# COMMON_POLICY_RPC_TIMEOUT=2000
#
# Internal RPC target list used by services that depend on provider-rpc.
# COMMON_PROVIDER_RPC_ENDPOINTS=provider-rpc:9003
#
# Default gRPC client timeout for provider-rpc calls, in milliseconds.
# COMMON_PROVIDER_RPC_TIMEOUT=2000
#
# Persistent storage backend shared by access-rpc and policy-rpc.
# Typical values:
# - pgredis: use PostgreSQL + Redis
# - memory: in-memory only, suitable for tests / throwaway runs
# COMMON_STORE_BACKEND=pgredis
#
# Full PostgreSQL DSN. If omitted, docker-compose generates it from
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB / POSTGRES_SSLMODE.
# COMMON_POSTGRES_DSN=postgres://xsonar:change-me-postgres-password@postgres:5432/xsonar?sslmode=disable
#
# Redis connection shared by services that need Redis.
COMMON_REDIS_ADDR=redis:6379
COMMON_REDIS_PASSWORD=
COMMON_REDIS_DB=0

# gateway-api public HTTP entrypoint.
# This is the external business API gateway.
GATEWAY_API_NAME=gateway-api
# Host and port listened on inside the container.
# In docker-compose, host is usually 0.0.0.0 and port should stay aligned with
# docker-compose.yml unless you know you need a different internal port.
GATEWAY_API_HOST=0.0.0.0
GATEWAY_API_PORT=8080
# Gateway-level request timeout in milliseconds.
GATEWAY_API_TIMEOUT=10000
# Downstream RPC client timeouts used by gateway-api, in milliseconds.
GATEWAY_API_ACCESS_RPC_TIMEOUT=5000
GATEWAY_API_POLICY_RPC_TIMEOUT=5000
GATEWAY_API_PROVIDER_RPC_TIMEOUT=10000

# console-api admin HTTP entrypoint.
# This is the admin / console API used for platform operations.
CONSOLE_API_NAME=console-api
CONSOLE_API_HOST=0.0.0.0
CONSOLE_API_PORT=8081
# JWT secret for console login tokens. Replace in any non-demo environment.
CONSOLE_API_JWT_SECRET=change-me-console-jwt-secret
# JWT issuer string embedded in generated console tokens.
CONSOLE_API_JWT_ISSUER=xsonar-console
# JWT expiration time in minutes.
CONSOLE_API_JWT_TTL_MINUTES=120

# access-rpc internal service.
ACCESS_RPC_NAME=access-rpc
# gRPC listen address inside the container.
ACCESS_RPC_LISTEN_ON=0.0.0.0:9001
# Bootstrap admin account for console login.
# If either username or password is blank, bootstrap admin seeding is disabled.
ACCESS_RPC_SEED_ADMIN_USERNAME=admin
ACCESS_RPC_SEED_ADMIN_PASSWORD=change-me-admin-password
# How often in-memory usage stats are flushed to persistent storage, in ms.
ACCESS_RPC_USAGE_STATS_FLUSH_INTERVAL_MS=60000
ACCESS_RPC_APP_METADATA_CACHE_TTL_MS=600000
ACCESS_RPC_APP_METADATA_CACHE_PREFIX=xsonar:

# policy-rpc internal service.
POLICY_RPC_NAME=policy-rpc
POLICY_RPC_LISTEN_ON=0.0.0.0:9002
# Default upstream provider API key used for seeded provider credentials.
# This is usually required if you want the built-in default policies to work.
POLICY_RPC_PROVIDER_API_KEY=replace-with-real-provider-api-key

# provider-rpc internal service.
PROVIDER_RPC_NAME=provider-rpc
PROVIDER_RPC_LISTEN_ON=0.0.0.0:9003
# Provider-rpc service timeout in milliseconds.
PROVIDER_RPC_TIMEOUT=10000
# Third-party upstream base URL, without the policy-managed path suffix.
PROVIDER_RPC_PROVIDER_BASE_URL=https://fapi.teleproxy.io/api
# Health-check path appended to PROVIDER_RPC_PROVIDER_BASE_URL.
PROVIDER_RPC_PROVIDER_HEALTH_PATH=/
# Header name used to forward provider API keys upstream.
PROVIDER_RPC_PROVIDER_API_KEY_HEADER=apiKey
# Outbound HTTP timeout for upstream provider calls, in milliseconds.
PROVIDER_RPC_PROVIDER_TIMEOUT_MS=8000
# Number of retries for idempotent upstream requests.
PROVIDER_RPC_PROVIDER_RETRY_COUNT=1

# scheduler-rpc internal service.
SCHEDULER_RPC_NAME=scheduler-rpc
SCHEDULER_RPC_LISTEN_ON=0.0.0.0:9004
SCHEDULER_RPC_TIMEOUT=5000

# collector-worker-rpc internal service.
COLLECTOR_WORKER_RPC_NAME=collector-worker-rpc
COLLECTOR_WORKER_RPC_LISTEN_ON=0.0.0.0:9005
COLLECTOR_WORKER_RPC_TIMEOUT=5000
